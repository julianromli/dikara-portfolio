# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# API (Hono + tRPC) — default port 3001; Vite proxies /trpc to this in dev.
PORT=3001

# SQLite file path relative to project root (optional; default data/app.db)
# SQLITE_PATH=data/app.db

# Optional: full tRPC URL for production builds (e.g. https://api.example.com/trpc)
# VITE_TRPC_URL=/trpc

# UploadThing (v7) — dari dashboard https://uploadthing.com/dashboard
# Diperlukan agar endpoint /api/uploadthing (Hono) bisa issue upload.
# UPLOADTHING_TOKEN=
