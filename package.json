{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"npm run dev:vite\" \"npm run dev:server\"",
    "dev:vite": "vite --port=5173 --host=127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node -e \"require('node:fs').mkdirSync('data',{recursive:true})\" && drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "npx --yes rimraf@6 dist",
    "clean:cache": "npx --yes rimraf@6 node_modules/.vite .vite",
    "reset-deps": "npx --yes rimraf@6 node_modules package-lock.json && npm install",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/trpc-server": "^0.4.2",
    "@tanstack/react-query": "^5.99.0",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "8.0.8"
  }
}
